{
	"name": "hoalu",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3",
			"zod": "^4.3.6",
			"react": "^19.2.5",
			"react-dom": "^19.2.5",
			"hono": "^4.12.15",
			"better-auth": "^1.6.9",
			"@better-auth/api-key": "^1.6.9",
			"@better-auth/core": "^1.6.9",
			"tailwindcss": "^4.2.4"
		}
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"dev:apps": "bun run scripts/dev.ts",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip-bun"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"knip": "^6.7.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.10"
	},
	"overrides": {
		"chalk": "5.6.2",
		"ora": "8.2.0",
		"@better-auth/core": "^1.6.9"
	},
	"packageManager": "bun@1.3.9",
	"trustedDependencies": [
		"@swc/core"
	]
}
