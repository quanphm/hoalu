{
	"name": "hoalu",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@types/bun": "^1.3.9",
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3",
			"zod": "^4.3.6",
			"react": "^19.2.4",
			"react-dom": "^19.2.4",
			"hono": "^4.12.2",
			"better-auth": "^1.5.0",
			"@better-auth/api-key": "^1.5.0",
			"tailwindcss": "^4.2.1"
		}
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip"
	},
	"devDependencies": {
		"knip": "^5.85.0",
		"oxfmt": "^0.31.0",
		"oxlint": "^1.50.0",
		"turbo": "^2.8.10",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"overrides": {
		"chalk": "5.6.2",
		"ora": "8.2.0"
	},
	"packageManager": "bun@1.3.9",
	"trustedDependencies": [
		"@swc/core"
	],
	"patchedDependencies": {
		"@better-auth/api-key@1.5.0": "patches/@better-auth%2Fapi-key@1.5.0.patch"
	}
}
