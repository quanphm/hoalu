{
	"name": "hoalu",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"dev:apps": "node scripts/dev.ts",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"knip": "^6.15.0",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"tsx": "^4.22.4",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"packageManager": "pnpm@11.5.2",
	"patchedDependencies": {
		"@better-auth/kysely-adapter@1.6.14": "patches/@better-auth%2Fkysely-adapter@1.6.14.patch"
	}
}
