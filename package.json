{
	"name": "hoalu",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@types/bun": "^1.3.11",
			"@types/react": "^19.2.14",
			"@types/react-dom": "^19.2.3",
			"zod": "^4.3.6",
			"react": "^19.2.4",
			"react-dom": "^19.2.4",
			"hono": "^4.12.3",
			"better-auth": "^1.5.1",
			"@better-auth/api-key": "^1.5.1",
			"@better-auth/core": "^1.5.1",
			"tailwindcss": "^4.2.2"
		}
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip-bun"
	},
	"devDependencies": {
		"knip": "^5.88.1",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"turbo": "^2.8.20",
		"typescript": "^5.9.3",
		"vite": "^8.0.1"
	},
	"overrides": {
		"chalk": "5.6.2",
		"ora": "8.2.0"
	},
	"packageManager": "bun@1.3.9",
	"trustedDependencies": [
		"@swc/core"
	]
}
