{
	"name": "hoalu",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@types/react": "^19.2.16",
			"@types/react-dom": "^19.2.3",
			"zod": "^4.4.3",
			"react": "^19.2.7",
			"react-dom": "^19.2.7",
			"hono": "^4.12.23",
			"better-auth": "^1.6.14",
			"@better-auth/api-key": "^1.6.14",
			"@better-auth/core": "^1.6.14",
			"tailwindcss": "^4.3.0"
		}
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"dev:apps": "bun run scripts/dev.ts",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip-bun"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"knip": "^6.15.0",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"overrides": {
		"@openrouter/sdk": "^0.12.79",
		"chalk": "5.6.2",
		"ora": "8.2.0"
	},
	"packageManager": "bun@1.3.9",
	"patchedDependencies": {
		"@better-auth/kysely-adapter@1.6.14": "patches/@better-auth%2Fkysely-adapter@1.6.14.patch"
	},
	"trustedDependencies": [
		"@swc/core"
	]
}
