{
	"name": "hoalu",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"dev:apps": "node scripts/dev.ts",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip"
	},
	"devDependencies": {
		"@types/node": "^25.9.5",
		"knip": "^6.17.1",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.73.0",
		"tsx": "^4.22.4",
		"turbo": "^2.10.4",
		"typescript": "^7.0.2",
		"vite": "^8.1.4"
	},
	"packageManager": "pnpm@11.11.0"
}
