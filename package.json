{
	"name": "hoalu",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev --filter=\"./apps/*\"",
		"dev:apps": "node scripts/dev.ts",
		"docker:up": "cd deployments && docker compose -f docker-compose.local.yml up -d --build",
		"docker:down": "cd deployments && docker compose -f docker-compose.local.yml down",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"knip": "knip"
	},
	"devDependencies": {
		"@types/node": "^25.9.5",
		"knip": "^6.27.0",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.74.0",
		"tsx": "^4.23.1",
		"turbo": "^2.10.5",
		"typescript": "^7.0.2",
		"vite": "^8.1.5"
	},
	"packageManager": "pnpm@11.13.1"
}
