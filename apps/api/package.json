{
	"name": "@hoalu/api",
	"version": "0.28.13",
	"files": [
		"dist"
	],
	"type": "module",
	"imports": {
		"#api/*": "./src/*"
	},
	"exports": {
		"./types": "./dist/types/index.d.ts"
	},
	"scripts": {
		"build:api": "bun build ./src/index.ts --outdir ./dist --target bun --production",
		"build:types": "bun tsc -p tsconfig.build.json",
		"prebuild": "bun run clean",
		"build": "bun run build:api && bun run build:types",
		"clean": "rimraf -rf dist",
		"dev": "bun db:migrate && bun --watch src/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@better-auth/api-key": "catalog:",
		"@better-auth/core": "catalog:",
		"@electric-sql/client": "^1.5.18",
		"@hoalu/auth": "workspace:*",
		"@hoalu/common": "workspace:*",
		"@hoalu/email": "workspace:*",
		"@hoalu/furnace": "workspace:*",
		"@hono/standard-validator": "^0.2.2",
		"@hono/zod-validator": "^0.8.0",
		"@react-email/render": "^2.0.8",
		"@scalar/hono-api-reference": "^0.10.16",
		"@tanstack/ai": "^0.20.1",
		"@tanstack/ai-openrouter": "^0.8.5",
		"better-auth": "catalog:",
		"drizzle-orm": "^0.45.2",
		"hono": "catalog:",
		"hono-openapi": "^1.2.0",
		"ioredis": "^5.10.1",
		"nodemailer": "^8.0.7",
		"pg": "^8.21.0",
		"react": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@hoalu/tsconfig": "workspace:*",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"@types/react": "catalog:",
		"drizzle-kit": "^0.31.10",
		"rimraf": "^6.1.3"
	}
}
