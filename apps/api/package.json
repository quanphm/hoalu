{
	"name": "@hoalu/api",
	"version": "0.30.6",
	"files": [
		"dist"
	],
	"type": "module",
	"imports": {
		"#api/*": "./src/*"
	},
	"exports": {
		"./types": "./dist/types/index.d.ts"
	},
	"scripts": {
		"build:api": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:argon2",
		"build:types": "tsc -p tsconfig.build.json",
		"prebuild": "pnpm run clean",
		"build": "pnpm run build:api && pnpm run build:types",
		"clean": "rimraf -rf dist",
		"dev": "pnpm db:migrate && tsx watch --env-file=.env src/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1088.0",
		"@aws-sdk/s3-request-presigner": "^3.1088.0",
		"@better-auth/api-key": "catalog:",
		"@better-auth/core": "catalog:",
		"@electric-sql/client": "^1.5.24",
		"@hoalu/auth": "workspace:*",
		"@hoalu/datetime": "workspace:*",
		"@hoalu/email": "workspace:*",
		"@hoalu/finance": "workspace:*",
		"@hoalu/furnace": "workspace:*",
		"@hoalu/http": "workspace:*",
		"@hoalu/ids": "workspace:*",
		"@hoalu/schema": "workspace:*",
		"@hoalu/stdlib": "workspace:*",
		"@hono/node-server": "^2.0.10",
		"@hono/standard-validator": "^0.2.3",
		"@hono/zod-validator": "^0.8.0",
		"@react-email/render": "^2.1.0",
		"@scalar/hono-api-reference": "^0.10.20",
		"@tanstack/ai": "^0.27.0",
		"@tanstack/ai-openrouter": "^0.13.4",
		"argon2": "^0.44.0",
		"better-auth": "catalog:",
		"drizzle-orm": "^0.45.2",
		"hono": "catalog:",
		"hono-openapi": "^1.3.1",
		"ioredis": "^5.11.0",
		"nodemailer": "^8.0.11",
		"pg": "^8.22.0",
		"react": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@hoalu/tsconfig": "workspace:*",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.20.0",
		"@types/react": "catalog:",
		"drizzle-kit": "^0.31.10",
		"esbuild": "^0.28.1",
		"rimraf": "^6.1.3"
	},
	"overrides": {
		"@tanstack/ai-openrouter>@openrouter/sdk": "^0.12.79"
	}
}
